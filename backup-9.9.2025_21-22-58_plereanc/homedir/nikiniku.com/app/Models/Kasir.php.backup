<?php  
  
namespace App\Models;  
  
use Illuminate\Database\Eloquent\Factories\HasFactory;  
use Illuminate\Database\Eloquent\Model;  
  
class Kasir extends Model  
{  
    use HasFactory;  
  
    protected $table = 'kasirs';  
  
    protected $fillable = [  
        'tindakan_id',  
        'obat_id',  
        'dokter_id', // Menambahkan foreign key untuk dokter  
        'nama_pasien',  
        'kasus',  
        'harga',  
        'biaya_admin',  
        'tanggal_transaksi', // Menambahkan tanggal transaksi ke dalam fillable  
    ];  
  
    public function tindakan()  
    {  
        return $this->belongsTo(Tindakan::class);  
    }  
  
    public function obat()  
    {  
        return $this->belongsTo(Obat::class);  
    }  
  
    public function dokter()  
    {  
        return $this->belongsTo(Dokter::class);  
    }  
  
    /**  
     * Update the doctor's earnings based on the transaction.  
     */  
    public function updateDoctorEarnings()  
    {  
        $dokter = $this->dokter()->first();  
        if ($dokter) {  
            $dokter->penghasilan += $this->harga; // Menambahkan harga transaksi ke penghasilan dokter  
            $dokter->save(); // Menyimpan perubahan  
        }  
    }  
}  
